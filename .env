# LLM model served by Ollama
# Options: llama3, llama3:8b, mistral, phi3, gemma, etc.
OLLAMA_MODEL=llama3

# Whisper model for audio transcription
# Accuracy vs speed trade-off:
#   tiny / base  → fastest, lower accuracy
#   small        → good for short recordings
#   medium       → recommended (good balance)
#   large-v3     → most accurate, very slow on CPU
WHISPER_MODEL=medium
